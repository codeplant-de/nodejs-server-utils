{
  "name": "@codeplant-de/nodejs-server-logger",
  "version": "2.1.0",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/codeplant-de/nodejs-server-utils",
    "directory": "packages/logger",
    "type": "git"
  },
  "scripts": {
    "lint": "cp-lint",
    "format": "cp-format",
