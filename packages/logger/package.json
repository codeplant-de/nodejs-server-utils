    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "jest-extended": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
