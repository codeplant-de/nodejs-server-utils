{
  "name": "@codeplant-de/nodejs-server-middleware",
  "version": "1.2.0",
  "main": "lib/index.js",
  "types": "lib/types.d.ts",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/codeplant-de/nodejs-server-utils",
    "directory": "packages/middleware",
    "type": "git"
  },
  "exports": {
    ".": {
      "types": "./lib/types.d.ts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "lint": "cp-lint",
    "format": "cp-format",
    "test": "jest",
    "test:types": "tsd --files ./src/**/*.test-d.ts",
    "typecheck": "tsc --noEmit",
    "build": "rimraf lib && npm run build:cjs && npm run build:types",
    "build:cjs": "cp-transpile -o lib cjs",
    "build:types": "cp-transpile -o lib types"
  },
  "dependencies": {
    "@codeplant-de/http-context-provider-middleware": "^1.1.4",
    "@codeplant-de/logger-provider-middleware": "^1.2.0",
    "@codeplant-de/request-id-provider-middleware": "^1.1.3",
    "@codeplant-de/request-logging-middleware": "^1.1.11",
    "@types/connect": "^3.4.38",
    "ts-essentials": "^10.1.1"
  },
  "devDependencies": {
    "@codeplant-de/nodejs-server-logger": "^2.1.0",
    "@types/express": "^4.17.15",
    "@types/supertest": "^7.2.0",
    "express": "^4.18.2",
    "supertest": "^7.2.2"
  },
  "peerDependencies": {
    "@codeplant-de/nodejs-server-logger": "^1.1.0 || ^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
