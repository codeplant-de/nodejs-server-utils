{
  "name": "@codeplant-de/apollo-server-v4-logging-middleware",
  "version": "1.2.0",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/codeplant-de/nodejs-server-utils",
    "directory": "middleware/apollo-server-logging",
    "type": "git"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "lint": "cp-lint",
    "format": "cp-format",
    "test": "jest",
    "test:types": "tsd --files ./src/**/*.test-d.ts",
    "typecheck": "tsc --noEmit",
    "build": "rimraf lib && npm run build:cjs && npm run build:types",
    "build:cjs": "cp-transpile -o lib cjs",
    "build:types": "cp-transpile -o lib types"
  },
  "devDependencies": {
    "@apollo/server": "^5.0.0",
    "graphql": "^16.13.1",
    "jest-extended": "^7.0.0"
  },
  "peerDependencies": {
    "@apollo/server": "^4.0.0 || ^5.0.0",
    "graphql": "^16.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
