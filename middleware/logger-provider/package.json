{
  "name": "@codeplant-de/logger-provider-middleware",
  "version": "1.2.0",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/codeplant-de/nodejs-server-utils",
    "directory": "middleware/logger-provider",
    "type": "git"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "lint": "cp-lint",
    "format": "cp-format",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "build": "rimraf lib && npm run build:cjs && npm run build:types",
    "build:cjs": "cp-transpile -o lib cjs",
    "build:types": "cp-transpile -o lib types"
  },
  "dependencies": {
    "@types/connect": "^3.4.38"
  },
  "devDependencies": {
    "@codeplant-de/nodejs-server-logger": "^2.1.0"
  },
  "peerDependencies": {
    "@codeplant-de/nodejs-server-logger": "^1.1.0 || ^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
