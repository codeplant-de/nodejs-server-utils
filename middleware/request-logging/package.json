{
  "name": "@codeplant-de/request-logging-middleware",
  "version": "1.1.11",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/codeplant-de/nodejs-server-utils",
    "directory": "middleware/request-logging",
    "type": "git"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "lint": "cp-lint",
    "format": "cp-format",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "build": "rimraf lib && npm run build:cjs && npm run build:types",
    "build:cjs": "cp-transpile -o lib cjs",
    "build:types": "cp-transpile -o lib types"
  },
  "dependencies": {
    "@types/connect": "^3.4.38",
    "on-finished": "^2.4.1",
    "on-headers": "^1.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.15",
    "@types/on-finished": "^2.3.5",
    "@types/on-headers": "^1.0.4",
    "jest": "^29.6.2",
    "percentile": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
