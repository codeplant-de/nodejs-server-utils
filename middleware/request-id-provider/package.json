{
  "name": "@codeplant-de/request-id-provider-middleware",
  "version": "1.1.3",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/codeplant-de/nodejs-server-utils",
    "directory": "middleware/request-id-provider",
    "type": "git"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "lint": "cp-lint",
    "format": "cp-format",
    "test": "jest",
